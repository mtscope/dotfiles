<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <add key="dependencyVersion" value="Highest" />
    <add key="signatureValidationMode" value="accept" />
    <add key="defaultPushSource" value="https://api.nuget.org/v3/index.json" />
  </config>

  <solution>
    <add key="disableSourceControlIntegration" value="true" />
  </solution>

  <bindingRedirects>
    <add key="skip" value="false" />
  </bindingRedirects>

  <packageRestore>
    <add key="enabled" value="true" />
    <add key="automatic" value="true" />
  </packageRestore>

  <packageSources>
    <clear />
    <add key="nuget" value="https://api.nuget.org/v3/index.json" />
    <add key="azure-emptyscope" value="https://pkgs.dev.azure.com/emptyscope/_packaging/v5/nuget/v3/index.json" />
    <add key="github-emptyscope" value="https://nuget.pkg.github.com/emptyscope/index.json" />
    <add key="gitlab-emptyscope" value="https://gitlab.com/api/v4/groups/57182844/-/packages/nuget/index.json" />
    <add key="azure-rxlightning" value="https://pkgs.dev.azure.com/rxlightning/_packaging/v5/nuget/v3/index.json" />
    <add key="github-rxlightning" value="https://nuget.pkg.github.com/rxlightninginc/index.json" />
    <add key="gitlab-rxlightning" value="https://gitlab.com/api/v4/groups/68102594/-/packages/nuget/index.json" />
  </packageSources>

  <apikeys>
    <add key="https://pkgs.dev.azure.com/emptyscope/_packaging/v5/nuget/v3/index.json" value="" />
    <add key="https://api.nuget.org/v3/index.json" value="" />
  </apikeys>

  <packageSourceCredentials>
    <github-emptyscope>
      <add key="Username" value="$GITHUB_USERNAME" />
      <add key="ClearTextPassword" value="$GITHUB_USERNAME" />
    </github-emptyscope>
    <gitlab-emptyscope>
      <add key="Username" value="$GITLAB_USERNAME" />
      <add key="ClearTextPassword" value="$GITLAB_ACCESS_TOKEN" />
    </gitlab-emptyscope>
    <github-rxlightning>
      <add key="Username" value="$GITHUB_USERNAME" />
      <add key="ClearTextPassword" value="$GITHUB_ACCESS_TOKEN" />
    </github-rxlightning>
    <gitlab-rxlightning>
      <add key="Username" value="$GITLAB_USERNAME" />
      <add key="ClearTextPassword" value="$GITLAB_ACCESS_TOKEN" />
    </gitlab-rxlightning>
  </packageSourceCredentials>

  <disabledPackageSources>
    <add key="azure-emptyscope" value="https://pkgs.dev.azure.com/emptyscope/_packaging/v5/nuget/v3/index.json" />
    <add key="azure-rxlightning" value="https://pkgs.dev.azure.com/rxlightning/_packaging/v5/nuget/v3/index.json" />
    <add key="github-emptyscope" value="https://nuget.pkg.github.com/emptyscope/index.json" />
    <add key="gitlab-emptyscope" value="https://gitlab.com/api/v4/groups/57182844/-/packages/nuget/index.json" />
    <add key="github-rxlightning" value="https://nuget.pkg.github.com/rxlightninginc/index.json" />
  </disabledPackageSources>

  <activePackageSource>
    <add key="nuget" value="https://api.nuget.org/v3/index.json" protocolVersion="3" allowInsecureConnections="false" />
    <add key="gitlab-rxlightning" value="https://gitlab.com/api/v4/groups/68102594/-/packages/nuget/index.json" allowInsecureConnections="false" />
    <add key="All" value="(Aggregate source)" />
  </activePackageSource>
</configuration>